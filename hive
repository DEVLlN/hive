#!/bin/bash
# hive — Multi-AI terminal chat. Talk to Claude and Codex from one prompt.
#
# Usage: hive [working-dir]
#
# Default: messages go to BOTH agents in parallel.
# c = claude only | x = codex only | cc/xx = interactive | collab = autonomous

set -uo pipefail  # no -e: don't exit on non-zero (agent calls can fail gracefully)

VERSION="0.2.0"
CWD="${1:-$(pwd)}"
cd "$CWD" || { echo "Cannot cd to $CWD"; exit 1; }

# ── Colors ───────────────────────────────────────────────────────
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
RED='\033[0;31m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── Config ───────────────────────────────────────────────────────
HIVE_DIR="${HIVE_DIR:-$CWD/.hive}"
HIVE_CLAUDE_MODEL="${HIVE_CLAUDE_MODEL:-claude-opus-4-6}"
HIVE_CODEX_FLAGS="${HIVE_CODEX_FLAGS:---full-auto --ephemeral}"
HIVE_CONTEXT_LINES="${HIVE_CONTEXT_LINES:-20}"
HIVE_ENSEMBLE_DIR="${HIVE_ENSEMBLE_DIR:-$HOME/ensemble}"

mkdir -p "$HIVE_DIR"
HISTORY_FILE="$HIVE_DIR/conversation.md"
STATS_FILE="$HIVE_DIR/stats.json"
SESSION_ID="$(date +%Y%m%d_%H%M%S)"

# ── Stats tracking ──────────────────────────────────────────────
CLAUDE_TOTAL_INPUT=0
CLAUDE_TOTAL_OUTPUT=0
CLAUDE_TOTAL_COST=0
CLAUDE_CALLS=0
CODEX_TOTAL_TOKENS=0
CODEX_CALLS=0

print_stats_bar() {
    local c_cost_fmt
    if (( $(echo "$CLAUDE_TOTAL_COST > 0" | bc -l 2>/dev/null || echo 0) )); then
        c_cost_fmt=$(printf '$%.2f' "$CLAUDE_TOTAL_COST")
    else
        c_cost_fmt='$0.00'
    fi

    local c_ctx=""
    if (( CLAUDE_TOTAL_INPUT > 0 )); then
        local pct=$((CLAUDE_TOTAL_INPUT * 100 / 1000000))
        # Build context bar (10 chars)
        local filled=$((pct / 10))
        local empty=$((10 - filled))
        local bar=""
        for ((i=0; i<filled; i++)); do bar+="●"; done
        for ((i=0; i<empty; i++)); do bar+="○"; done
        c_ctx="${bar} ${pct}%"
    else
        c_ctx="○○○○○○○○○○ 0%"
    fi

    echo -ne "\033[s"  # save cursor
    # Move to top line
    echo -ne "\033[1;1H\033[2K"
    echo -ne "  ${GREEN}● Claude${RESET} ${DIM}${HIVE_CLAUDE_MODEL}${RESET} | "
    echo -ne "${DIM}ctx:${RESET} ${c_ctx} | "
    echo -ne "${DIM}cost:${RESET} ${c_cost_fmt} | "
    echo -ne "${DIM}calls:${RESET} ${CLAUDE_CALLS}"
    echo -ne "  ${BLUE}◆ Codex${RESET} ${DIM}gpt-5.2${RESET} | "
    echo -ne "${DIM}tokens:${RESET} ${CODEX_TOTAL_TOKENS} | "
    echo -ne "${DIM}calls:${RESET} ${CODEX_CALLS}"
    echo -ne "\033[u"  # restore cursor
}

# ── Context builder ─────────────────────────────────────────────
build_context() {
    local msg="$1"
    local ctx=""

    # Project context
    if [[ -f "$CWD/CLAUDE.md" ]]; then
        ctx="You are working in $CWD. Read CLAUDE.md for project context. "
    fi

    # Cross-session memory
    for mem in \
        "$HOME/.claude/projects/-$(echo "$CWD" | tr '/' '-')/memory/MEMORY.md" \
        "$HOME/.claude/projects/-Users-$(whoami)/memory/MEMORY.md"; do
        if [[ -f "$mem" ]]; then
            ctx="${ctx}Read $mem for cross-session learnings. "
            break
        fi
    done

    # Conversation history
    if [[ -f "$HISTORY_FILE" ]] && [[ -s "$HISTORY_FILE" ]]; then
        local tail_ctx
        tail_ctx=$(tail -"$HIVE_CONTEXT_LINES" "$HISTORY_FILE" 2>/dev/null | tr '\n' ' ')
        ctx="${ctx}Recent conversation: ${tail_ctx} "
    fi

    printf '%s\n\nNow answer: %s' "$ctx" "$msg"
}

log_history() {
    printf '### %s [%s]\n%s\n\n' "$1" "$(date +%H:%M:%S)" "$2" >> "$HISTORY_FILE"
}

# ── Agent callers ───────────────────────────────────────────────
ask_claude() {
    local msg="$1"
    local ctx
    ctx=$(build_context "$msg")

    # Use stream-json to capture stats
    local tmpout="/tmp/hive-claude-stream.jsonl"
    claude -p --model "$HIVE_CLAUDE_MODEL" --output-format stream-json --verbose "$ctx" > "$tmpout" 2>/dev/null || true

    # Extract the text result
    local result
    result=$(grep '"type":"result"' "$tmpout" 2>/dev/null | head -1)
    local text
    text=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('result',''))" 2>/dev/null || cat "$tmpout" 2>/dev/null)

    # Extract stats
    local input_tokens output_tokens cost
    input_tokens=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); u=d.get('usage',{}); print(u.get('input_tokens',0) + u.get('cache_read_input_tokens',0) + u.get('cache_creation_input_tokens',0))" 2>/dev/null || echo 0)
    output_tokens=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('usage',{}).get('output_tokens',0))" 2>/dev/null || echo 0)
    cost=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('total_cost_usd',0))" 2>/dev/null || echo 0)

    # Update totals
    CLAUDE_TOTAL_INPUT=$((CLAUDE_TOTAL_INPUT + ${input_tokens:-0}))
    CLAUDE_TOTAL_OUTPUT=$((CLAUDE_TOTAL_OUTPUT + ${output_tokens:-0}))
    CLAUDE_TOTAL_COST=$(echo "$CLAUDE_TOTAL_COST + ${cost:-0}" | bc -l 2>/dev/null || echo "$CLAUDE_TOTAL_COST")
    CLAUDE_CALLS=$((CLAUDE_CALLS + 1))

    echo "$text"
}

ask_codex() {
    local msg="$1"
    local ctx
    ctx=$(build_context "$msg")

    # Codex with JSON output for stats
    local tmpout="/tmp/hive-codex-stream.jsonl"
    # shellcheck disable=SC2086
    codex exec $HIVE_CODEX_FLAGS -C "$CWD" --json -o /tmp/hive-codex-out.txt "$ctx" > "$tmpout" 2>/dev/null || true

    local text
    text=$(cat /tmp/hive-codex-out.txt 2>/dev/null)

    # Extract token count from JSON output
    local tokens
    tokens=$(grep -o '"tokens used"' "$tmpout" 2>/dev/null | wc -l || echo 0)
    if [[ -z "$tokens" ]] || [[ "$tokens" == "0" ]]; then
        # Try to extract from the last line of stderr/json
        tokens=$(grep -o '"total_tokens":[0-9]*' "$tmpout" 2>/dev/null | tail -1 | grep -o '[0-9]*' || echo 0)
    fi

    CODEX_TOTAL_TOKENS=$((CODEX_TOTAL_TOKENS + ${tokens:-0}))
    CODEX_CALLS=$((CODEX_CALLS + 1))

    echo "$text"
}

# ── Header ──────────────────────────────────────────────────────
clear
echo ""
echo -e "  ${BOLD}${CYAN}⬡ hive${RESET} ${DIM}v${VERSION}${RESET}"
echo -e "  ${DIM}default = both | c = claude | x = codex | cc/xx = interactive | collab = autonomous${RESET}"
echo -e "  ${DIM}dir: ${CWD}${RESET}"
echo -e ""
echo -e "  ${GREEN}● Claude${RESET} ${DIM}${HIVE_CLAUDE_MODEL} (1M context)${RESET}    ${BLUE}◆ Codex${RESET} ${DIM}gpt-5.2-codex${RESET}"
echo -e "  ${DIM}──────────────────────────────────────────────────────────────────${RESET}"
echo ""

# Session marker
printf -- '---\n## Session %s\n\n' "$SESSION_ID" >> "$HISTORY_FILE"

# ── Main loop ───────────────────────────────────────────────────
while true; do
    echo -ne "${CYAN}⬡${RESET} "
    read -r input || break
    [[ -z "$input" ]] && continue

    cmd="${input%% *}"
    rest="${input#* }"
    [[ "$cmd" == "$input" ]] && rest=""

    case "$cmd" in
        c|claude)
            [[ -z "$rest" ]] && { echo -e "${DIM}Usage: c <message>${RESET}"; continue; }
            log_history "You → Claude" "$rest"
            echo -e "${GREEN}● Claude:${RESET}"
            response=$(ask_claude "$rest")
            echo "$response"
            log_history "Claude" "$response"
            echo ""
            echo -e "${DIM}  ╰─ ctx: ${CLAUDE_TOTAL_INPUT} tokens | cost: \$$(printf '%.2f' "$CLAUDE_TOTAL_COST") | calls: ${CLAUDE_CALLS}${RESET}"
            echo ""
            ;;

        x|codex)
            [[ -z "$rest" ]] && { echo -e "${DIM}Usage: x <message>${RESET}"; continue; }
            log_history "You → Codex" "$rest"
            echo -e "${BLUE}◆ Codex:${RESET}"
            response=$(ask_codex "$rest")
            echo "$response"
            log_history "Codex" "$response"
            echo ""
            echo -e "${DIM}  ╰─ tokens: ${CODEX_TOTAL_TOKENS} | calls: ${CODEX_CALLS}${RESET}"
            echo ""
            ;;

        cc)
            echo -e "${DIM}Entering Claude interactive (full context, skills, hooks)...${RESET}"
            claude --model "$HIVE_CLAUDE_MODEL" --dangerously-skip-permissions
            echo -e "${DIM}Back in hive${RESET}"
            ;;

        xx)
            echo -e "${DIM}Entering Codex interactive...${RESET}"
            codex
            echo -e "${DIM}Back in hive${RESET}"
            ;;

        collab)
            [[ -z "$rest" ]] && { echo -e "${DIM}Usage: collab <task>${RESET}"; continue; }
            log_history "You → Collab" "$rest"
            if [[ -d "$HIVE_ENSEMBLE_DIR" ]]; then
                echo -e "${DIM}Launching autonomous collab...${RESET}"
                (cd "$HIVE_ENSEMBLE_DIR" && node bin/ensemble.cjs run "$rest" --agents claude,codex) &
                sleep 3
                echo -e "${DIM}Monitor: cd $HIVE_ENSEMBLE_DIR && node bin/ensemble.cjs monitor --latest${RESET}"
            else
                echo -e "${RED}Ensemble not found at $HIVE_ENSEMBLE_DIR${RESET}"
            fi
            ;;

        history)
            if [[ -f "$HISTORY_FILE" ]] && [[ -s "$HISTORY_FILE" ]]; then
                echo -e "${DIM}─── Conversation History ───${RESET}"
                cat "$HISTORY_FILE"
                echo -e "${DIM}────────────────────────────${RESET}"
            else
                echo -e "${DIM}No history yet${RESET}"
            fi
            ;;

        stats)
            echo -e "${DIM}─── Session Stats ───${RESET}"
            echo -e "  ${GREEN}● Claude${RESET}  input: ${CLAUDE_TOTAL_INPUT} tokens | output: ${CLAUDE_TOTAL_OUTPUT} tokens | cost: \$$(printf '%.2f' "$CLAUDE_TOTAL_COST") | calls: ${CLAUDE_CALLS}"
            echo -e "  ${BLUE}◆ Codex${RESET}   tokens: ${CODEX_TOTAL_TOKENS} | calls: ${CODEX_CALLS}"
            echo -e "${DIM}─────────────────────${RESET}"
            ;;

        clear)
            : > "$HISTORY_FILE"
            echo -e "${DIM}History cleared${RESET}"
            ;;

        q|quit|exit)
            echo ""
            echo -e "${DIM}─── Final Stats ───${RESET}"
            echo -e "  ${GREEN}● Claude${RESET}  input: ${CLAUDE_TOTAL_INPUT} tokens | output: ${CLAUDE_TOTAL_OUTPUT} tokens | cost: \$$(printf '%.2f' "$CLAUDE_TOTAL_COST") | calls: ${CLAUDE_CALLS}"
            echo -e "  ${BLUE}◆ Codex${RESET}   tokens: ${CODEX_TOTAL_TOKENS} | calls: ${CODEX_CALLS}"
            echo -e "${DIM}────────────────────${RESET}"
            echo ""
            break
            ;;

        *)
            # DEFAULT: ask BOTH in parallel
            log_history "You → Both" "$input"

            ask_claude "$input" > /tmp/hive-claude-both.txt 2>/dev/null &
            CPID=$!
            ask_codex "$input" > /tmp/hive-codex-both.txt 2>/dev/null &
            XPID=$!

            echo -e "${DIM}asking both...${RESET}"
            echo ""

            wait $CPID 2>/dev/null
            echo -e "${GREEN}● Claude:${RESET}"
            c_resp=$(cat /tmp/hive-claude-both.txt 2>/dev/null)
            echo "$c_resp"
            log_history "Claude" "$c_resp"

            echo ""

            wait $XPID 2>/dev/null
            echo -e "${BLUE}◆ Codex:${RESET}"
            x_resp=$(cat /tmp/hive-codex-both.txt 2>/dev/null)
            echo "$x_resp"
            log_history "Codex" "$x_resp"

            echo ""
            echo -e "${DIM}  ╰─ claude: ${CLAUDE_TOTAL_INPUT} ctx tokens, \$$(printf '%.2f' "$CLAUDE_TOTAL_COST") | codex: ${CODEX_TOTAL_TOKENS} tokens | calls: $((CLAUDE_CALLS + CODEX_CALLS))${RESET}"
            echo ""
            ;;
    esac
done
