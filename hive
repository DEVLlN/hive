#!/bin/bash
# hive — Multi-AI terminal chat. Talk to Claude and Codex from one prompt.
#
# Usage: hive [working-dir]
#
# Default: messages go to BOTH agents in parallel.
# c = claude only | x = codex only | cc/xx = interactive | collab = autonomous

set -uo pipefail

VERSION="0.3.0"
CWD="${1:-$(pwd)}"
cd "$CWD" || { echo "Cannot cd to $CWD"; exit 1; }

# ── Colors ───────────────────────────────────────────────────────
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
RED='\033[0;31m'
WHITE='\033[1;37m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'
BG_DARK='\033[48;5;236m'  # dark gray background for status bar
FG_GREEN='\033[38;5;114m'
FG_BLUE='\033[38;5;111m'
FG_GRAY='\033[38;5;245m'
FG_WHITE='\033[38;5;255m'
FG_YELLOW='\033[38;5;221m'
FG_MAGENTA='\033[38;5;176m'
FG_CYAN='\033[38;5;116m'

# ── Config ───────────────────────────────────────────────────────
HIVE_DIR="${HIVE_DIR:-$CWD/.hive}"
HIVE_CLAUDE_MODEL="${HIVE_CLAUDE_MODEL:-claude-opus-4-6}"
HIVE_CODEX_FLAGS="${HIVE_CODEX_FLAGS:---full-auto --ephemeral}"
HIVE_CONTEXT_LINES="${HIVE_CONTEXT_LINES:-20}"
HIVE_ENSEMBLE_DIR="${HIVE_ENSEMBLE_DIR:-$HOME/ensemble}"

mkdir -p "$HIVE_DIR"
HISTORY_FILE="$HIVE_DIR/conversation.md"
SESSION_ID="$(date +%Y%m%d_%H%M%S)"
SESSION_START=$(date +%s)

# Project name from directory
PROJECT_NAME=$(basename "$CWD")
# Git branch
GIT_BRANCH=$(git -C "$CWD" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "—")

# ── Stats tracking ──────────────────────────────────────────────
CLAUDE_LAST_INPUT=0       # per-call context usage
CLAUDE_TOTAL_OUTPUT=0
CLAUDE_TOTAL_CACHE_READ=0
CLAUDE_TOTAL_COST="0.00"
CLAUDE_CALLS=0
CLAUDE_MAX_CTX=1000000    # 1M context window
CODEX_LAST_INPUT=0        # per-call context usage
CODEX_TOTAL_OUTPUT=0
CODEX_TOTAL_CACHED=0
CODEX_CALLS=0
CODEX_MAX_CTX=128000      # 128k context window
TOTAL_QUESTIONS=0

# Detect Codex model from config
CODEX_MODEL=$(grep '^model' ~/.codex/config.toml 2>/dev/null | head -1 | sed 's/.*= *"//;s/"//' || echo "gpt-5.2-codex")

# ── Terminal setup for bottom bar ───────────────────────────────
TERM_LINES=$(tput lines)
TERM_COLS=$(tput cols)
BAR_LINES=3  # 3-line status bar at bottom

setup_scroll_region() {
    TERM_LINES=$(tput lines)
    TERM_COLS=$(tput cols)
    # Set scrolling region to leave bottom 3 lines free
    printf '\033[1;%dr' "$((TERM_LINES - BAR_LINES))"
    # Move cursor to top of scroll region
    printf '\033[%d;1H' "$((TERM_LINES - BAR_LINES))"
}

restore_terminal() {
    # Reset scroll region to full terminal
    printf '\033[r'
    # Move cursor to bottom
    printf '\033[%d;1H' "$TERM_LINES"
    echo ""
    tput cnorm  # show cursor
}

trap restore_terminal EXIT
trap 'TERM_LINES=$(tput lines); TERM_COLS=$(tput cols); draw_status_bar' WINCH

# ── Status bar drawing ──────────────────────────────────────────
make_bar() {
    # Usage: make_bar <percent> — returns colored ●○ bar
    local pct=${1:-0}
    local filled=$((pct / 10))
    local empty=$((10 - filled))
    local bar=""
    for ((i=0; i<filled; i++)); do bar+="●"; done
    for ((i=0; i<empty; i++)); do bar+="○"; done
    echo "$bar"
}

draw_status_bar() {
    TERM_LINES=$(tput lines)
    TERM_COLS=$(tput cols)

    local now=$(date +%s)
    local elapsed=$(( now - SESSION_START ))
    local mins=$(( elapsed / 60 ))
    local secs=$(( elapsed % 60 ))
    local duration="${mins}m${secs}s"
    local time_now=$(date +"%l:%M%p" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    # ── Claude context bar (per-call) ──
    local c_ctx_pct=0
    if (( CLAUDE_LAST_INPUT > 0 )); then
        c_ctx_pct=$((CLAUDE_LAST_INPUT * 100 / CLAUDE_MAX_CTX))
    fi
    local c_bar=$(make_bar $c_ctx_pct)
    local c_color="$FG_GREEN"
    if (( c_ctx_pct > 70 )); then c_color="$RED"; elif (( c_ctx_pct > 40 )); then c_color="$FG_YELLOW"; fi
    local c_cost=$(printf '%.2f' "$CLAUDE_TOTAL_COST" 2>/dev/null || echo "0.00")

    # ── Codex context bar (per-call) ──
    local x_ctx_pct=0
    if (( CODEX_LAST_INPUT > 0 )); then
        x_ctx_pct=$((CODEX_LAST_INPUT * 100 / CODEX_MAX_CTX))
    fi
    local x_bar=$(make_bar $x_ctx_pct)
    local x_color="$FG_BLUE"
    if (( x_ctx_pct > 70 )); then x_color="$RED"; elif (( x_ctx_pct > 40 )); then x_color="$FG_YELLOW"; fi

    # Git dirty flag
    local git_dirty=""
    if [[ -n $(git -C "$CWD" status --porcelain 2>/dev/null | head -1) ]]; then
        git_dirty="*"
    fi

    tput sc

    # Show cost only if using API key
    local claude_cost_section=""
    if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        claude_cost_section=" │ ${FG_GRAY}cost${RESET}${BG_DARK} ${FG_WHITE}\$${c_cost}${RESET}${BG_DARK}"
    fi

    # ── Line 1: Claude ──
    tput cup "$((TERM_LINES - BAR_LINES))" 0
    printf "${BG_DARK}%-${TERM_COLS}s${RESET}" ""
    tput cup "$((TERM_LINES - BAR_LINES))" 0
    printf "${BG_DARK} ${FG_GREEN}● Claude${RESET}${BG_DARK}  ${FG_GREEN}Opus 4.6 (1M context)${RESET}${BG_DARK} │ ${c_color}${c_bar}${RESET}${BG_DARK} ${FG_WHITE}${c_ctx_pct}%%${RESET}${BG_DARK}${claude_cost_section} │ ${FG_MAGENTA}${PROJECT_NAME}${RESET}${BG_DARK} ${FG_GRAY}(${GIT_BRANCH}${git_dirty})${RESET}${BG_DARK}"

    # ── Line 2: Codex ──
    tput cup "$((TERM_LINES - BAR_LINES + 1))" 0
    printf "${BG_DARK}%-${TERM_COLS}s${RESET}" ""
    tput cup "$((TERM_LINES - BAR_LINES + 1))" 0
    printf "${BG_DARK} ${FG_BLUE}◆ Codex${RESET}${BG_DARK}   ${FG_BLUE}${CODEX_MODEL} (128k)${RESET}${BG_DARK}       │ ${x_color}${x_bar}${RESET}${BG_DARK} ${FG_WHITE}${x_ctx_pct}%%${RESET}${BG_DARK} │ ${FG_GRAY}questions${RESET}${BG_DARK} ${FG_WHITE}${TOTAL_QUESTIONS}${RESET}${BG_DARK}"

    # ── Line 3: Hive ──
    tput cup "$((TERM_LINES - BAR_LINES + 2))" 0
    printf "${BG_DARK}%-${TERM_COLS}s${RESET}" ""
    tput cup "$((TERM_LINES - BAR_LINES + 2))" 0
    local mode_display
    case "$MODE" in
        claude) mode_display="${FG_GREEN}● claude${RESET}${BG_DARK}" ;;
        codex)  mode_display="${FG_BLUE}◆ codex${RESET}${BG_DARK}" ;;
        *)      mode_display="${FG_CYAN}both${RESET}${BG_DARK}" ;;
    esac
    printf "${BG_DARK} ${FG_CYAN}⬡ hive${RESET}${BG_DARK} ${FG_GRAY}v${VERSION}${RESET}${BG_DARK} │ ${FG_GRAY}mode:${RESET}${BG_DARK} ${mode_display} ${FG_GRAY}(shift+tab)${RESET}${BG_DARK} │ ${FG_GRAY}c │ x │ cc │ xx │ collab │ stats │ q${RESET}${BG_DARK}"

    tput rc
}

# ── Thinking spinners ───────────────────────────────────────────
# Claude-style verbs
CLAUDE_VERBS=("Pondering" "Thinking" "Reasoning" "Analyzing" "Considering" "Evaluating" "Reflecting")
CODEX_VERBS=("Processing" "Computing" "Generating" "Resolving" "Synthesizing" "Working" "Inferring")

spin_claude() {
    # Usage: spin_claude &   then kill $! when done
    local pid_file="$1"
    local start=$(date +%s)
    local i=0
    local verb_idx=$((RANDOM % ${#CLAUDE_VERBS[@]}))
    local verb="${CLAUDE_VERBS[$verb_idx]}"
    local frames=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")

    while true; do
        local elapsed=$(( $(date +%s) - start ))
        local s=$((elapsed % 60))
        local m=$((elapsed / 60))
        local time_str
        if (( m > 0 )); then
            time_str="${m}m ${s}s"
        else
            time_str="${s}s"
        fi

        # Rotate verb every 15s
        if (( elapsed > 0 && elapsed % 15 == 0 )); then
            verb_idx=$(( (verb_idx + 1) % ${#CLAUDE_VERBS[@]} ))
            verb="${CLAUDE_VERBS[$verb_idx]}"
        fi

        local frame="${frames[$((i % ${#frames[@]}))]}"
        printf "\r${GREEN}${frame} ${verb}…${RESET} ${DIM}(${time_str})${RESET}  "
        i=$((i + 1))
        sleep 0.2
    done
}

spin_codex() {
    local pid_file="$1"
    local start=$(date +%s)
    local i=0
    local verb_idx=$((RANDOM % ${#CODEX_VERBS[@]}))
    local verb="${CODEX_VERBS[$verb_idx]}"
    local frames=("◇" "◈" "◆" "◈")

    while true; do
        local elapsed=$(( $(date +%s) - start ))
        local s=$((elapsed % 60))
        local m=$((elapsed / 60))
        local time_str
        if (( m > 0 )); then
            time_str="${m}m ${s}s"
        else
            time_str="${s}s"
        fi

        if (( elapsed > 0 && elapsed % 15 == 0 )); then
            verb_idx=$(( (verb_idx + 1) % ${#CODEX_VERBS[@]} ))
            verb="${CODEX_VERBS[$verb_idx]}"
        fi

        local frame="${frames[$((i % ${#frames[@]}))]}"
        printf "\r${BLUE}${frame} ${verb}…${RESET} ${DIM}(${time_str})${RESET}  "
        i=$((i + 1))
        sleep 0.3
    done
}

spin_both() {
    local start=$(date +%s)
    local i=0
    local c_verb_idx=$((RANDOM % ${#CLAUDE_VERBS[@]}))
    local x_verb_idx=$((RANDOM % ${#CODEX_VERBS[@]}))
    local c_frames=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
    local x_frames=("◇" "◈" "◆" "◈")

    while true; do
        local elapsed=$(( $(date +%s) - start ))
        local s=$((elapsed % 60))
        local m=$((elapsed / 60))
        local time_str
        if (( m > 0 )); then time_str="${m}m ${s}s"; else time_str="${s}s"; fi

        if (( elapsed > 0 && elapsed % 12 == 0 )); then
            c_verb_idx=$(( (c_verb_idx + 1) % ${#CLAUDE_VERBS[@]} ))
            x_verb_idx=$(( (x_verb_idx + 1) % ${#CODEX_VERBS[@]} ))
        fi

        local cf="${c_frames[$((i % ${#c_frames[@]}))]}"
        local xf="${x_frames[$((i % ${#x_frames[@]}))]}"
        printf "\r${GREEN}${cf} ${CLAUDE_VERBS[$c_verb_idx]}…${RESET}  ${BLUE}${xf} ${CODEX_VERBS[$x_verb_idx]}…${RESET}  ${DIM}(${time_str})${RESET}    "
        i=$((i + 1))
        sleep 0.25
    done
}

# ── Context builder ─────────────────────────────────────────────
build_context() {
    local msg="$1"
    local ctx=""

    if [[ -f "$CWD/CLAUDE.md" ]]; then
        ctx="You are working in $CWD. Read CLAUDE.md for project context. "
    fi

    for mem in \
        "$HOME/.claude/projects/-$(echo "$CWD" | tr '/' '-')/memory/MEMORY.md" \
        "$HOME/.claude/projects/-Users-$(whoami)/memory/MEMORY.md"; do
        if [[ -f "$mem" ]]; then
            ctx="${ctx}Read $mem for cross-session learnings. "
            break
        fi
    done

    if [[ -f "$HISTORY_FILE" ]] && [[ -s "$HISTORY_FILE" ]]; then
        local tail_ctx
        tail_ctx=$(tail -"$HIVE_CONTEXT_LINES" "$HISTORY_FILE" 2>/dev/null | tr '\n' ' ')
        ctx="${ctx}Recent conversation: ${tail_ctx} "
    fi

    printf '%s\n\nNow answer: %s' "$ctx" "$msg"
}

log_history() {
    printf '### %s [%s]\n%s\n\n' "$1" "$(date +%H:%M:%S)" "$2" >> "$HISTORY_FILE"
}

# ── Agent callers ───────────────────────────────────────────────
ask_claude() {
    local msg="$1"
    local ctx
    ctx=$(build_context "$msg")

    local tmpout="/tmp/hive-claude-stream.jsonl"
    claude -p --model "$HIVE_CLAUDE_MODEL" --output-format stream-json --verbose "$ctx" > "$tmpout" 2>/dev/null || true

    local result
    result=$(grep '"type":"result"' "$tmpout" 2>/dev/null | head -1)

    local text
    text=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('result',''))" 2>/dev/null || echo "")

    if [[ -z "$text" ]]; then
        text=$(claude -p --model "$HIVE_CLAUDE_MODEL" "$ctx" 2>/dev/null || echo "(no response)")
    fi

    # Extract stats
    local input_tokens output_tokens cost
    input_tokens=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); u=d.get('usage',{}); print(int(u.get('input_tokens',0)) + int(u.get('cache_read_input_tokens',0)) + int(u.get('cache_creation_input_tokens',0)))" 2>/dev/null || echo 0)
    output_tokens=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(int(d.get('usage',{}).get('output_tokens',0)))" 2>/dev/null || echo 0)
    cost=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('total_cost_usd',0))" 2>/dev/null || echo 0)

    local cache_read
    cache_read=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(int(d.get('usage',{}).get('cache_read_input_tokens',0)))" 2>/dev/null || echo 0)

    CLAUDE_LAST_INPUT=${input_tokens:-0}
    CLAUDE_TOTAL_OUTPUT=$((CLAUDE_TOTAL_OUTPUT + ${output_tokens:-0}))
    CLAUDE_TOTAL_CACHE_READ=$((CLAUDE_TOTAL_CACHE_READ + ${cache_read:-0}))
    CLAUDE_TOTAL_COST=$(python3 -c "print(round(${CLAUDE_TOTAL_COST} + ${cost:-0}, 4))" 2>/dev/null || echo "$CLAUDE_TOTAL_COST")
    CLAUDE_CALLS=$((CLAUDE_CALLS + 1))

    echo "$text"
}

ask_codex() {
    local msg="$1"
    local ctx
    ctx=$(build_context "$msg")

    local tmpout="/tmp/hive-codex-stream.jsonl"
    # shellcheck disable=SC2086
    codex exec $HIVE_CODEX_FLAGS -C "$CWD" --json -o /tmp/hive-codex-out.txt "$ctx" > "$tmpout" 2>/dev/null || true

    local text
    text=$(cat /tmp/hive-codex-out.txt 2>/dev/null)

    # Extract detailed token stats from JSON stream
    local input_t cached_t output_t
    input_t=$(grep -o '"input_tokens":[0-9]*' "$tmpout" 2>/dev/null | tail -1 | grep -o '[0-9]*' || echo 0)
    cached_t=$(grep -o '"cached_input_tokens":[0-9]*' "$tmpout" 2>/dev/null | tail -1 | grep -o '[0-9]*' || echo 0)
    output_t=$(grep -o '"output_tokens":[0-9]*' "$tmpout" 2>/dev/null | tail -1 | grep -o '[0-9]*' || echo 0)

    CODEX_LAST_INPUT=${input_t:-0}
    CODEX_TOTAL_CACHED=$((CODEX_TOTAL_CACHED + ${cached_t:-0}))
    CODEX_TOTAL_OUTPUT=$((CODEX_TOTAL_OUTPUT + ${output_t:-0}))
    CODEX_CALLS=$((CODEX_CALLS + 1))

    echo "$text"
}

# ── Mode management ─────────────────────────────────────────────
MODE="both"  # default: both, claude, codex
MODE_COLORS=("${CYAN}" "${GREEN}" "${BLUE}")
MODE_NAMES=("both" "claude" "codex")
MODE_LABELS=("${CYAN}both${RESET}" "${GREEN}● claude${RESET}" "${BLUE}◆ codex${RESET}")
MODE_PROMPTS=("${CYAN}❯${RESET}" "${GREEN}❯${RESET}" "${BLUE}❯${RESET}")
MODE_INDEX=0

get_mode_label() {
    echo -e "${MODE_LABELS[$MODE_INDEX]}"
}

cycle_mode() {
    MODE_INDEX=$(( (MODE_INDEX + 1) % 3 ))
    MODE="${MODE_NAMES[$MODE_INDEX]}"
}

# ── Config persistence ──────────────────────────────────────────
CONFIG_FILE="$HIVE_DIR/config"

load_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        local saved_mode
        saved_mode=$(grep '^default_mode=' "$CONFIG_FILE" 2>/dev/null | cut -d= -f2)
        case "$saved_mode" in
            claude) MODE="claude"; MODE_INDEX=1 ;;
            codex)  MODE="codex";  MODE_INDEX=2 ;;
            *)      MODE="both";   MODE_INDEX=0 ;;
        esac
    fi
}

save_config() {
    echo "default_mode=$MODE" > "$CONFIG_FILE"
}

# ── Startup ─────────────────────────────────────────────────────
clear

# First-time setup: pick default mode
if [[ ! -f "$CONFIG_FILE" ]]; then
    echo ""
    echo -e "  ${BOLD}${CYAN}⬡ hive${RESET} ${DIM}v${VERSION}${RESET} — Multi-AI terminal chat"
    echo -e "  ${DIM}${PROJECT_NAME} (${GIT_BRANCH})${RESET}"
    echo ""
    echo -e "  ${BOLD}Choose your default mode:${RESET}"
    echo ""
    echo -e "    ${CYAN}1${RESET}  ${CYAN}both${RESET}    — ask Claude + Codex in parallel ${DIM}(recommended)${RESET}"
    echo -e "    ${GREEN}2${RESET}  ${GREEN}claude${RESET}  — ask Claude only"
    echo -e "    ${BLUE}3${RESET}  ${BLUE}codex${RESET}   — ask Codex only"
    echo ""
    echo -e "  ${DIM}You can switch anytime with shift+tab or type c/x/both${RESET}"
    echo ""
    echo -ne "  ${BOLD}Pick [1/2/3]:${RESET} "
    read -r mode_choice
    case "$mode_choice" in
        2) MODE="claude"; MODE_INDEX=1 ;;
        3) MODE="codex";  MODE_INDEX=2 ;;
        *) MODE="both";   MODE_INDEX=0 ;;
    esac
    save_config
    echo ""
    echo -e "  ${DIM}Default set to$(get_mode_label). Saved to ${CONFIG_FILE}${RESET}"
    sleep 1
    clear
else
    load_config
fi

setup_scroll_region

echo ""
echo -e "  ${BOLD}${CYAN}⬡ hive${RESET} ${DIM}v${VERSION}${RESET} — Multi-AI terminal chat"
echo -e "  ${DIM}${PROJECT_NAME} (${GIT_BRANCH}) │ mode:$(get_mode_label) ${DIM}(shift+tab to cycle)${RESET}"
echo ""

draw_status_bar

# Session marker
printf -- '---\n## Session %s\n\n' "$SESSION_ID" >> "$HISTORY_FILE"

# ── Custom read with shift+tab detection ────────────────────────
read_with_mode_toggle() {
    # Read input char by char to detect shift+tab (ESC [ Z)
    local input=""
    local char

    # Show prompt with current mode indicator
    echo -ne "${MODE_PROMPTS[$MODE_INDEX]} "

    while IFS= read -rsn1 char; do
        case "$char" in
            $'\x1b')
                # Escape sequence — read next chars
                IFS= read -rsn1 -t 0.1 char2 || true
                IFS= read -rsn1 -t 0.1 char3 || true
                if [[ "$char2" == "[" && "$char3" == "Z" ]]; then
                    # Shift+Tab detected — cycle mode
                    cycle_mode
                    save_config
                    # Redraw prompt line
                    printf "\r\033[2K"
                    echo -ne "${MODE_PROMPTS[$MODE_INDEX]} ${input}"
                else
                    # Other escape sequence, ignore
                    :
                fi
                ;;
            "")
                # Enter pressed
                echo ""
                break
                ;;
            $'\x7f'|$'\b')
                # Backspace
                if [[ -n "$input" ]]; then
                    input="${input%?}"
                    printf "\b \b"
                fi
                ;;
            *)
                input+="$char"
                printf '%s' "$char"
                ;;
        esac
    done

    REPLY="$input"
}

# ── Main loop ───────────────────────────────────────────────────
while true; do
    # Separator line above prompt
    printf "${DIM}"
    printf '%.0s─' $(seq 1 "$TERM_COLS")
    printf "${RESET}\n"

    read_with_mode_toggle
    input="$REPLY"

    # Separator line below prompt
    printf "${DIM}"
    printf '%.0s─' $(seq 1 "$TERM_COLS")
    printf "${RESET}\n"
    [[ -z "$input" ]] && continue

    TOTAL_QUESTIONS=$((TOTAL_QUESTIONS + 1))

    cmd="${input%% *}"
    rest="${input#* }"
    [[ "$cmd" == "$input" ]] && rest=""

    # Check for explicit mode prefix, otherwise use current mode
    case "$cmd" in
        c|claude|x|codex|cc|xx|collab|history|stats|clear|q|quit|exit)
            ;; # handled below as before
        both)
            # Explicit "both" prefix
            cmd="both_explicit"
            ;;
        *)
            # No prefix — route based on current mode
            case "$MODE" in
                claude) cmd="c"; rest="$input" ;;
                codex)  cmd="x"; rest="$input" ;;
                both)   cmd="both_default"; rest="$input" ;;
            esac
            ;;
    esac

    case "$cmd" in
        c|claude)
            [[ -z "$rest" ]] && { echo -e "${DIM}Usage: c <message>${RESET}"; continue; }
            log_history "You → Claude" "$rest"
            spin_claude &
            SPIN_PID=$!
            response=$(ask_claude "$rest")
            kill $SPIN_PID 2>/dev/null; wait $SPIN_PID 2>/dev/null
            printf "\r\033[2K"  # clear spinner line
            echo -e "${GREEN}● Claude:${RESET}"
            echo "$response"
            log_history "Claude" "$response"
            echo ""
            draw_status_bar
            ;;

        x|codex)
            [[ -z "$rest" ]] && { echo -e "${DIM}Usage: x <message>${RESET}"; continue; }
            log_history "You → Codex" "$rest"
            spin_codex &
            SPIN_PID=$!
            response=$(ask_codex "$rest")
            kill $SPIN_PID 2>/dev/null; wait $SPIN_PID 2>/dev/null
            printf "\r\033[2K"
            echo -e "${BLUE}◆ Codex:${RESET}"
            echo "$response"
            log_history "Codex" "$response"
            echo ""
            draw_status_bar
            ;;

        cc)
            restore_terminal
            echo -e "${DIM}Entering Claude interactive...${RESET}"
            claude --model "$HIVE_CLAUDE_MODEL" --dangerously-skip-permissions
            echo -e "${DIM}Back in hive${RESET}"
            setup_scroll_region
            draw_status_bar
            ;;

        xx)
            restore_terminal
            echo -e "${DIM}Entering Codex interactive...${RESET}"
            codex
            echo -e "${DIM}Back in hive${RESET}"
            setup_scroll_region
            draw_status_bar
            ;;

        collab)
            [[ -z "$rest" ]] && { echo -e "${DIM}Usage: collab <task>${RESET}"; continue; }
            log_history "You → Collab" "$rest"
            if [[ -d "$HIVE_ENSEMBLE_DIR" ]]; then
                echo -e "${DIM}Launching autonomous collab...${RESET}"
                (cd "$HIVE_ENSEMBLE_DIR" && node bin/ensemble.cjs run "$rest" --agents claude,codex) &
                sleep 3
                echo -e "${DIM}Monitor: cd $HIVE_ENSEMBLE_DIR && node bin/ensemble.cjs monitor --latest${RESET}"
            else
                echo -e "${RED}Ensemble not found at $HIVE_ENSEMBLE_DIR${RESET}"
            fi
            ;;

        history)
            if [[ -f "$HISTORY_FILE" ]] && [[ -s "$HISTORY_FILE" ]]; then
                echo -e "${DIM}─── Conversation History ───${RESET}"
                cat "$HISTORY_FILE"
                echo -e "${DIM}────────────────────────────${RESET}"
            else
                echo -e "${DIM}No history yet${RESET}"
            fi
            ;;

        stats)
            draw_status_bar
            echo -e "${DIM}(stats bar updated)${RESET}"
            ;;

        clear)
            : > "$HISTORY_FILE"
            echo -e "${DIM}History cleared${RESET}"
            ;;

        q|quit|exit)
            break
            ;;

        both_default|both_explicit)
            # Ask BOTH in parallel
            log_history "You → Both" "$rest"

            ask_claude "$rest" > /tmp/hive-claude-both.txt 2>/dev/null &
            CPID=$!
            ask_codex "$rest" > /tmp/hive-codex-both.txt 2>/dev/null &
            XPID=$!

            # Show dual spinner while both think
            spin_both &
            SPIN_PID=$!

            # Wait for Claude first (usually faster)
            wait $CPID 2>/dev/null
            kill $SPIN_PID 2>/dev/null; wait $SPIN_PID 2>/dev/null
            printf "\r\033[2K"

            echo -e "${GREEN}● Claude:${RESET}"
            c_resp=$(cat /tmp/hive-claude-both.txt 2>/dev/null)
            echo "$c_resp"
            log_history "Claude" "$c_resp"
            echo ""

            # Show codex spinner if still running
            if kill -0 $XPID 2>/dev/null; then
                spin_codex &
                SPIN_PID=$!
                wait $XPID 2>/dev/null
                kill $SPIN_PID 2>/dev/null; wait $SPIN_PID 2>/dev/null
                printf "\r\033[2K"
            else
                wait $XPID 2>/dev/null
            fi

            echo -e "${BLUE}◆ Codex:${RESET}"
            x_resp=$(cat /tmp/hive-codex-both.txt 2>/dev/null)
            echo "$x_resp"
            log_history "Codex" "$x_resp"

            echo ""
            draw_status_bar
            ;;
    esac
done
