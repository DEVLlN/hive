#!/bin/bash
# hive вЂ” Multi-AI terminal chat. Talk to Claude and Codex from one prompt.
#
# Usage: hive [working-dir]
#
# Default: messages go to BOTH agents in parallel.
# c = claude only | x = codex only | cc/xx = interactive | collab = autonomous

set -uo pipefail

VERSION="0.3.0"
CWD="${1:-$(pwd)}"
cd "$CWD" || { echo "Cannot cd to $CWD"; exit 1; }

# в”Ђв”Ђ Colors в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
RED='\033[0;31m'
WHITE='\033[1;37m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'
BG_DARK='\033[48;5;236m'  # dark gray background for status bar
FG_GREEN='\033[38;5;114m'
FG_BLUE='\033[38;5;111m'
FG_GRAY='\033[38;5;245m'
FG_WHITE='\033[38;5;255m'
FG_YELLOW='\033[38;5;221m'
FG_MAGENTA='\033[38;5;176m'
FG_CYAN='\033[38;5;116m'

# в”Ђв”Ђ Config в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
HIVE_DIR="${HIVE_DIR:-$CWD/.hive}"
HIVE_CLAUDE_MODEL="${HIVE_CLAUDE_MODEL:-claude-opus-4-6}"
HIVE_CODEX_FLAGS="${HIVE_CODEX_FLAGS:---full-auto --ephemeral}"
HIVE_CONTEXT_LINES="${HIVE_CONTEXT_LINES:-20}"
HIVE_ENSEMBLE_DIR="${HIVE_ENSEMBLE_DIR:-$HOME/ensemble}"

mkdir -p "$HIVE_DIR"
HISTORY_FILE="$HIVE_DIR/conversation.md"
SESSION_ID="$(date +%Y%m%d_%H%M%S)"
SESSION_START=$(date +%s)

# Project name from directory
PROJECT_NAME=$(basename "$CWD")
# Git branch
GIT_BRANCH=$(git -C "$CWD" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "вЂ”")

# в”Ђв”Ђ Stats tracking в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
CLAUDE_TOTAL_INPUT=0
CLAUDE_TOTAL_OUTPUT=0
CLAUDE_TOTAL_COST="0.00"
CLAUDE_CALLS=0
CODEX_TOTAL_TOKENS=0
CODEX_CALLS=0
TOTAL_QUESTIONS=0

# в”Ђв”Ђ Terminal setup for bottom bar в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
TERM_LINES=$(tput lines)
TERM_COLS=$(tput cols)
BAR_LINES=3  # 3-line status bar at bottom

setup_scroll_region() {
    TERM_LINES=$(tput lines)
    TERM_COLS=$(tput cols)
    # Set scrolling region to leave bottom 3 lines free
    printf '\033[1;%dr' "$((TERM_LINES - BAR_LINES))"
    # Move cursor to top of scroll region
    printf '\033[%d;1H' "$((TERM_LINES - BAR_LINES))"
}

restore_terminal() {
    # Reset scroll region to full terminal
    printf '\033[r'
    # Move cursor to bottom
    printf '\033[%d;1H' "$TERM_LINES"
    echo ""
    tput cnorm  # show cursor
}

trap restore_terminal EXIT
trap 'TERM_LINES=$(tput lines); TERM_COLS=$(tput cols); draw_status_bar' WINCH

# в”Ђв”Ђ Status bar drawing в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
draw_status_bar() {
    TERM_LINES=$(tput lines)
    TERM_COLS=$(tput cols)

    local now=$(date +%s)
    local elapsed=$(( now - SESSION_START ))
    local mins=$(( elapsed / 60 ))
    local secs=$(( elapsed % 60 ))
    local duration="${mins}m${secs}s"

    # Context usage bar for Claude (out of 1M)
    local ctx_pct=0
    if (( CLAUDE_TOTAL_INPUT > 0 )); then
        ctx_pct=$((CLAUDE_TOTAL_INPUT * 100 / 1000000))
    fi
    local filled=$((ctx_pct / 10))
    local empty=$((10 - filled))
    local ctx_bar=""
    local ctx_color="$FG_GREEN"
    if (( ctx_pct > 70 )); then ctx_color="$RED"; elif (( ctx_pct > 40 )); then ctx_color="$FG_YELLOW"; fi
    for ((i=0; i<filled; i++)); do ctx_bar+="в—Џ"; done
    for ((i=0; i<empty; i++)); do ctx_bar+="в—‹"; done

    # Cost formatting
    local cost_fmt
    cost_fmt=$(printf '%.2f' "$CLAUDE_TOTAL_COST" 2>/dev/null || echo "0.00")

    # Save cursor position
    tput sc

    # в”Ђв”Ђ Line 1: Claude stats в”Ђв”Ђ
    tput cup "$((TERM_LINES - BAR_LINES))" 0
    printf "${BG_DARK}%${TERM_COLS}s${RESET}" ""  # clear line with bg
    tput cup "$((TERM_LINES - BAR_LINES))" 0
    printf "${BG_DARK} ${FG_GREEN}в—Џ Claude${RESET}${BG_DARK} ${FG_GRAY}${HIVE_CLAUDE_MODEL} (1M)${RESET}${BG_DARK} в”‚ ${ctx_color}${ctx_bar}${RESET}${BG_DARK} ${FG_WHITE}${ctx_pct}%%${RESET}${BG_DARK} в”‚ ${FG_GRAY}cost:${RESET}${BG_DARK} ${FG_WHITE}\$${cost_fmt}${RESET}${BG_DARK} в”‚ ${FG_GRAY}out:${RESET}${BG_DARK} ${FG_WHITE}${CLAUDE_TOTAL_OUTPUT}${RESET}${BG_DARK} в”‚ ${FG_GRAY}calls:${RESET}${BG_DARK} ${FG_WHITE}${CLAUDE_CALLS}${RESET}${BG_DARK}"

    # в”Ђв”Ђ Line 2: Codex stats в”Ђв”Ђ
    tput cup "$((TERM_LINES - BAR_LINES + 1))" 0
    printf "${BG_DARK}%${TERM_COLS}s${RESET}" ""
    tput cup "$((TERM_LINES - BAR_LINES + 1))" 0
    printf "${BG_DARK} ${FG_BLUE}в—† Codex${RESET}${BG_DARK}  ${FG_GRAY}gpt-5.2-codex${RESET}${BG_DARK}       в”‚ ${FG_GRAY}tokens:${RESET}${BG_DARK} ${FG_WHITE}${CODEX_TOTAL_TOKENS}${RESET}${BG_DARK} в”‚ ${FG_GRAY}calls:${RESET}${BG_DARK} ${FG_WHITE}${CODEX_CALLS}${RESET}${BG_DARK} в”‚ ${FG_GRAY}questions:${RESET}${BG_DARK} ${FG_WHITE}${TOTAL_QUESTIONS}${RESET}${BG_DARK} в”‚ ${FG_GRAY}session:${RESET}${BG_DARK} ${FG_WHITE}${duration}${RESET}${BG_DARK}"

    # в”Ђв”Ђ Line 3: Project info в”Ђв”Ђ
    tput cup "$((TERM_LINES - BAR_LINES + 2))" 0
    printf "${BG_DARK}%${TERM_COLS}s${RESET}" ""
    tput cup "$((TERM_LINES - BAR_LINES + 2))" 0
    printf "${BG_DARK} ${FG_CYAN}в¬Ў hive${RESET}${BG_DARK} ${FG_GRAY}v${VERSION}${RESET}${BG_DARK} в”‚ ${FG_MAGENTA}${PROJECT_NAME}${RESET}${BG_DARK} ${FG_GRAY}(${GIT_BRANCH})${RESET}${BG_DARK} в”‚ ${FG_GRAY}default: both${RESET}${BG_DARK} в”‚ ${FG_GRAY}c = claude в”‚ x = codex в”‚ cc/xx = interactive в”‚ collab = autonomous${RESET}${BG_DARK}"

    # Restore cursor
    tput rc
}

# в”Ђв”Ђ Context builder в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
build_context() {
    local msg="$1"
    local ctx=""

    if [[ -f "$CWD/CLAUDE.md" ]]; then
        ctx="You are working in $CWD. Read CLAUDE.md for project context. "
    fi

    for mem in \
        "$HOME/.claude/projects/-$(echo "$CWD" | tr '/' '-')/memory/MEMORY.md" \
        "$HOME/.claude/projects/-Users-$(whoami)/memory/MEMORY.md"; do
        if [[ -f "$mem" ]]; then
            ctx="${ctx}Read $mem for cross-session learnings. "
            break
        fi
    done

    if [[ -f "$HISTORY_FILE" ]] && [[ -s "$HISTORY_FILE" ]]; then
        local tail_ctx
        tail_ctx=$(tail -"$HIVE_CONTEXT_LINES" "$HISTORY_FILE" 2>/dev/null | tr '\n' ' ')
        ctx="${ctx}Recent conversation: ${tail_ctx} "
    fi

    printf '%s\n\nNow answer: %s' "$ctx" "$msg"
}

log_history() {
    printf '### %s [%s]\n%s\n\n' "$1" "$(date +%H:%M:%S)" "$2" >> "$HISTORY_FILE"
}

# в”Ђв”Ђ Agent callers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
ask_claude() {
    local msg="$1"
    local ctx
    ctx=$(build_context "$msg")

    local tmpout="/tmp/hive-claude-stream.jsonl"
    claude -p --model "$HIVE_CLAUDE_MODEL" --output-format stream-json --verbose "$ctx" > "$tmpout" 2>/dev/null || true

    local result
    result=$(grep '"type":"result"' "$tmpout" 2>/dev/null | head -1)

    local text
    text=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('result',''))" 2>/dev/null || echo "")

    if [[ -z "$text" ]]; then
        text=$(claude -p --model "$HIVE_CLAUDE_MODEL" "$ctx" 2>/dev/null || echo "(no response)")
    fi

    # Extract stats
    local input_tokens output_tokens cost
    input_tokens=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); u=d.get('usage',{}); print(int(u.get('input_tokens',0)) + int(u.get('cache_read_input_tokens',0)) + int(u.get('cache_creation_input_tokens',0)))" 2>/dev/null || echo 0)
    output_tokens=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(int(d.get('usage',{}).get('output_tokens',0)))" 2>/dev/null || echo 0)
    cost=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('total_cost_usd',0))" 2>/dev/null || echo 0)

    CLAUDE_TOTAL_INPUT=$((CLAUDE_TOTAL_INPUT + ${input_tokens:-0}))
    CLAUDE_TOTAL_OUTPUT=$((CLAUDE_TOTAL_OUTPUT + ${output_tokens:-0}))
    CLAUDE_TOTAL_COST=$(python3 -c "print(round(${CLAUDE_TOTAL_COST} + ${cost:-0}, 4))" 2>/dev/null || echo "$CLAUDE_TOTAL_COST")
    CLAUDE_CALLS=$((CLAUDE_CALLS + 1))

    echo "$text"
}

ask_codex() {
    local msg="$1"
    local ctx
    ctx=$(build_context "$msg")

    local tmpout="/tmp/hive-codex-stream.jsonl"
    # shellcheck disable=SC2086
    codex exec $HIVE_CODEX_FLAGS -C "$CWD" --json -o /tmp/hive-codex-out.txt "$ctx" > "$tmpout" 2>/dev/null || true

    local text
    text=$(cat /tmp/hive-codex-out.txt 2>/dev/null)

    # Try to get token count
    local tokens
    tokens=$(grep -o '"total_tokens":[0-9]*' "$tmpout" 2>/dev/null | tail -1 | grep -o '[0-9]*' || echo 0)
    [[ -z "$tokens" ]] && tokens=0

    CODEX_TOTAL_TOKENS=$((CODEX_TOTAL_TOKENS + tokens))
    CODEX_CALLS=$((CODEX_CALLS + 1))

    echo "$text"
}

# в”Ђв”Ђ Startup в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
clear
setup_scroll_region

echo ""
echo -e "  ${BOLD}${CYAN}в¬Ў hive${RESET} ${DIM}v${VERSION}${RESET} вЂ” Multi-AI terminal chat"
echo -e "  ${DIM}${PROJECT_NAME} (${GIT_BRANCH})${RESET}"
echo ""

draw_status_bar

# Session marker
printf -- '---\n## Session %s\n\n' "$SESSION_ID" >> "$HISTORY_FILE"

# в”Ђв”Ђ Main loop в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
while true; do
    echo -ne "${GREEN}вќЇ${RESET} "
    read -r input || break
    [[ -z "$input" ]] && continue

    TOTAL_QUESTIONS=$((TOTAL_QUESTIONS + 1))

    cmd="${input%% *}"
    rest="${input#* }"
    [[ "$cmd" == "$input" ]] && rest=""

    case "$cmd" in
        c|claude)
            [[ -z "$rest" ]] && { echo -e "${DIM}Usage: c <message>${RESET}"; continue; }
            log_history "You в†’ Claude" "$rest"
            echo -e "${GREEN}в—Џ Claude:${RESET}"
            response=$(ask_claude "$rest")
            echo "$response"
            log_history "Claude" "$response"
            echo ""
            draw_status_bar
            ;;

        x|codex)
            [[ -z "$rest" ]] && { echo -e "${DIM}Usage: x <message>${RESET}"; continue; }
            log_history "You в†’ Codex" "$rest"
            echo -e "${BLUE}в—† Codex:${RESET}"
            response=$(ask_codex "$rest")
            echo "$response"
            log_history "Codex" "$response"
            echo ""
            draw_status_bar
            ;;

        cc)
            restore_terminal
            echo -e "${DIM}Entering Claude interactive...${RESET}"
            claude --model "$HIVE_CLAUDE_MODEL" --dangerously-skip-permissions
            echo -e "${DIM}Back in hive${RESET}"
            setup_scroll_region
            draw_status_bar
            ;;

        xx)
            restore_terminal
            echo -e "${DIM}Entering Codex interactive...${RESET}"
            codex
            echo -e "${DIM}Back in hive${RESET}"
            setup_scroll_region
            draw_status_bar
            ;;

        collab)
            [[ -z "$rest" ]] && { echo -e "${DIM}Usage: collab <task>${RESET}"; continue; }
            log_history "You в†’ Collab" "$rest"
            if [[ -d "$HIVE_ENSEMBLE_DIR" ]]; then
                echo -e "${DIM}Launching autonomous collab...${RESET}"
                (cd "$HIVE_ENSEMBLE_DIR" && node bin/ensemble.cjs run "$rest" --agents claude,codex) &
                sleep 3
                echo -e "${DIM}Monitor: cd $HIVE_ENSEMBLE_DIR && node bin/ensemble.cjs monitor --latest${RESET}"
            else
                echo -e "${RED}Ensemble not found at $HIVE_ENSEMBLE_DIR${RESET}"
            fi
            ;;

        history)
            if [[ -f "$HISTORY_FILE" ]] && [[ -s "$HISTORY_FILE" ]]; then
                echo -e "${DIM}в”Ђв”Ђв”Ђ Conversation History в”Ђв”Ђв”Ђ${RESET}"
                cat "$HISTORY_FILE"
                echo -e "${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RESET}"
            else
                echo -e "${DIM}No history yet${RESET}"
            fi
            ;;

        stats)
            draw_status_bar
            echo -e "${DIM}(stats bar updated)${RESET}"
            ;;

        clear)
            : > "$HISTORY_FILE"
            echo -e "${DIM}History cleared${RESET}"
            ;;

        q|quit|exit)
            break
            ;;

        *)
            # DEFAULT: ask BOTH in parallel
            log_history "You в†’ Both" "$input"

            ask_claude "$input" > /tmp/hive-claude-both.txt 2>/dev/null &
            CPID=$!
            ask_codex "$input" > /tmp/hive-codex-both.txt 2>/dev/null &
            XPID=$!

            echo -e "${DIM}asking both...${RESET}"
            echo ""

            wait $CPID 2>/dev/null
            echo -e "${GREEN}в—Џ Claude:${RESET}"
            c_resp=$(cat /tmp/hive-claude-both.txt 2>/dev/null)
            echo "$c_resp"
            log_history "Claude" "$c_resp"

            echo ""

            wait $XPID 2>/dev/null
            echo -e "${BLUE}в—† Codex:${RESET}"
            x_resp=$(cat /tmp/hive-codex-both.txt 2>/dev/null)
            echo "$x_resp"
            log_history "Codex" "$x_resp"

            echo ""
            draw_status_bar
            ;;
    esac
done
